\item \normalfont Relevant Coursework: \VAR{edu.coursework | join(", ")}, etc.
\end{zitemize}
\BLOCK{endif}
\BLOCK{if not loop.last}

\BLOCK{endif}
\BLOCK{endfor}
\vspace{4mm} % Add space between title and list

\section{Work Experience (By Project Per Organization)}
\BLOCK{for company in data.experience}
%====================
\BLOCK{if company.contracted_via}
\subsection{\VAR{company.role | latex_escape} @ \VAR{company.company | latex_escape} (\VAR{company.industry | latex_escape}; Contracted via \VAR{company.contracted_via | latex_escape}) \hfill \VAR{company.years}}
\BLOCK{elif company.acquired_by}
\subsection{\VAR{company.role | latex_escape} @ \VAR{company.company | latex_escape} (acquired by \VAR{company.acquired_by | latex_escape}) \hfill \VAR{company.years}}
\BLOCK{else}
