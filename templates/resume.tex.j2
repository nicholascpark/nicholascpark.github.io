\BLOCK{else}
\subsection{{\VAR{edu.degree | latex_escape}} | \textit{\VAR{edu.institution | latex_escape}} \hfill \VAR{edu.years}}
\BLOCK{endif}
\BLOCK{if edu.coursework}
