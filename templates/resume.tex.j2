\BLOCK{endif}
\vspace{0.5em}
\BLOCK{for project in company.projects}
\BLOCK{if loop.first}
\subtext{\textbf{\VAR{project.name | latex_escape}\BLOCK{if project.technologies}   (\VAR{project.technologies | join(", ") | latex_escape})\BLOCK{endif}}}
\BLOCK{else}
\subsection{\textbf{\textit{\VAR{project.name | latex_escape}\BLOCK{if project.technologies}   (\VAR{project.technologies | join(", ") | latex_escape})\BLOCK{endif}}}}
\vspace{0.1em}
\BLOCK{endif}
\begin{zitemize}
\BLOCK{for highlight in project.highlights}
\item \VAR{highlight | trim | latex_escape}
\BLOCK{endfor}
\end{zitemize}
\BLOCK{if not loop.last}

\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{if company.company in page_break_after}

\pagebreak
\BLOCK{elif not loop.last}
